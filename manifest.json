{
  "manifest_version": 3,
  "name": "Substack Archiver",
  "version": "1.0.0",
  "description": "Archive Substack articles as self-contained HTML for personal offline storage.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "downloads",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.substack.com/*",
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.substack.com/*", "*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
